POSTGRES_USER=garage
POSTGRES_PASSWORD=changeme
POSTGRES_DB=garage

JWT_SECRET=changeme-generate-a-long-random-string

# 최초 관리자 계정 (npm run seed -w apps/api 실행 시 사용)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=관리자

# --- 아래는 나중에 해당 기능을 켤 때만 필요 ---
# CLOUDFLARE_TUNNEL_TOKEN=   # cloudflared 서비스 주석 해제 시

# 오피넷(www.opinet.co.kr) 오픈API에서 발급받은 키. 미설정 시 주변 주유소 조회가
# 실제와 비슷한 목(mock) 데이터로 자동 폴백되므로, 실사용 전까지는 없어도 동작함.
# OPINET_API_KEY=

# 한국환경공단 전기차 충전소 정보 API(data.go.kr) 키. 미설정 시 주변 충전소 조회가
# 목(mock) 데이터로 자동 폴백됨. 활용신청은 기본 2년 후 자동 만료되니 /integrations에서
# 만료일도 함께 등록해두면 30일 전부터 경고가 표시됨.
# EV_CHARGER_API_KEY=

# 카카오맵 / 네이버 지도 / T맵 (선택). 미설정 시 OpenStreetMap만 사용됩니다.
# KAKAO_MAP_APP_KEY=
# NAVER_MAP_CLIENT_ID=
# TMAP_APP_KEY=

# PWA Web Push (리마인더 알림). 생성: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
